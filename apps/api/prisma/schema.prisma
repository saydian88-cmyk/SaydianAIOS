  orders            Int      @default(0)
  revenue           Decimal? @db.Decimal(18, 2)
  currency          String?
  occurredAt        DateTime
  metadata          Json     @default("{}")
  createdAt         DateTime @default(now())

  contentPlan     ContentPlan?     @relation(fields: [contentPlanId], references: [id], onDelete: SetNull)
  publishJob      PublishJob?      @relation(fields: [publishJobId], references: [id], onDelete: SetNull)
  integration     Integration?     @relation(fields: [integrationId], references: [id], onDelete: SetNull)
  platformAccount PlatformAccount? @relation(fields: [platformAccountId], references: [id], onDelete: SetNull)

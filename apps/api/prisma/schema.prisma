  recordsImported      Int          @default(0)
  recordsRejected      Int          @default(0)
  unavailableFields    String[]
  errors               Json         @default("[]")
  metadata             Json         @default("{}")
  completedAt          DateTime?
  createdAt            DateTime     @default(now())

  integration        Integration        @relation(fields: [integrationId], references: [id], onDelete: Restrict)
  platformAccount    PlatformAccount?   @relation(fields: [platformAccountId], references: [id], onDelete: SetNull)
  importedByEmployee Employee?          @relation(fields: [importedByEmployeeId], references: [id], onDelete: SetNull)

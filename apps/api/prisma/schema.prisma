generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum IntegrationKind {
  DOUYIN
  TIKTOK
  AMAZON
  SHOPIFY
  WECHAT_CHANNELS
  XIAOHONGSHU
  WECHAT_OFFICIAL
  WECOM
  TMALL
  JD
  PINDUODUO
  SAIDIAN_MALL
  JUSHUITAN
  FEIGUA
  WEB_SEARCH
  LOCAL_ASSET
  WECOM_DRIVE
  HELP_CENTER
  EVIDENCE_WORKBOOK
  ALIYUN_OSS
}

enum IntegrationState {
  UNCONFIGURED
  CONFIGURED
  HEALTHY
  DEGRADED
  ERROR
}

enum RecordStatus {
  DRAFT
  PENDING
  READY
  BLOCKED
  ARCHIVED
}

enum ContentStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  SCHEDULED
  PUBLISHED
  FAILED
}

enum ContentKind {
  VIDEO
  ARTICLE
  SHORT_POST
  WECHAT_MOMENT
}

enum JobStatus {
  PENDING
  RUNNING
  RETRY
  SUCCEEDED
  FAILED
  CANCELLED
}

enum AlertLevel {
  INFO
  WARNING
  CRITICAL
}

enum WorkItemType {
  CUSTOMER_SERVICE
  SHIPMENT
  AFTER_SALE
  REFUND
  WORK_ORDER
}

enum ReportKind {
  DAILY
  WEEKLY
  COMPETITOR
  LIVE_REVIEW
  SHOP
  TREND
}

enum ActorType {
  HUMAN
  AI
  SYSTEM
  PLATFORM
}

enum BusinessSnapshotType {
  PRODUCT
  INVENTORY
  ORDER
  SHIPMENT
  AFTER_SALE
  REFUND
  CUSTOMER_SERVICE
  WORK_ORDER
}

enum ImportStatus {
  PENDING
  RUNNING
  SUCCEEDED
  PARTIAL
  FAILED
}

enum AssetKind {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
}

enum AssetLevel {
  ORIGINAL
  MODULE
  FINISHED
  REFERENCE
  AI_GENERATED
}

enum ProductScope {
  MODEL
  SERIES
  BRAND
  COMMON
  UNKNOWN
}

enum AssetProcessingStatus {
  RECEIVED
  HASHED
  STORED
  ANALYZING
  READY_FOR_REVIEW
  FAILED
}

enum AssetReviewStatus {
  PENDING
  APPROVED
  RETURNED
  REJECTED
}

enum AssetAvailabilityStatus {
  INACTIVE
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum AssetRightsStatus {
  COMMERCIAL
  INTERNAL
  EDIT_ONLY
  AUTH_REQUIRED
  EXPIRED
  PROHIBITED
}

enum VideoModuleType {
  HOOK
  PAIN
  SCENE
  FEATURE
  BENEFIT
  PROOF
  DEMO
  COMPARE
  UGC
  STORY
  TRANSITION
  TRAFFIC
  OFFER
  CTA
  ENDING
}

enum AssetTagSource {
  AI
  HUMAN
  IMPORT
  RULE
}

enum AssetRelationType {
  SOURCE_OF
  SEGMENT_OF
  DERIVED_FROM
  PREVIEW_OF
  NEAR_DUPLICATE
  DUPLICATE_OF
}

enum AssetJobType {
  TECHNICAL_METADATA
  THUMBNAIL
  PROXY_VIDEO
  OCR
  TRANSCRIPTION
  KEYFRAMES
  SCENE_SEGMENTATION
  CONTENT_UNDERSTANDING
  TAGGING
  NEAR_DUPLICATE
}

enum AssetJobStatus {
  PENDING
  RUNNING
  RETRY
  SUCCEEDED
  FAILED
  UNCONFIGURED
}

enum CloudMediaProvider {
  ALIYUN_IMS
  ALIYUN_BAILIAN
}

enum CloudMediaJobType {
  MEDIA_INFO
  PROXY_VIDEO
  SCREENSHOTS
  SEGMENTATION
  TRANSCRIPTION
  VIDEO_UNDERSTANDING
  SEGMENT_ANALYSIS
  MODULE_CLASSIFICATION
  ASSET_SCORING
  REMAKE_BRIEF
}

enum CloudMediaJobStatus {
  PENDING
  SUBMITTED
  PROCESSING
  RETRY
  SUCCEEDED
  FAILED
  UNCONFIGURED
}

enum AssetScoreKind {
  OWNED_ASSET
  EXTERNAL_REFERENCE
}

enum ExternalVideoStatus {
  DISCOVERED
  QUEUED
  ANALYZING
  READY
  FAILED
  ARCHIVED
}

enum RemakeTaskStatus {
  PENDING_CONFIRMATION
  CONFIRMED
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  REJECTED
  CANCELLED
}

enum UploadBatchStatus {
  DRAFT
  UPLOADING
  PROCESSING
  COMPLETED
  PARTIAL
  FAILED
}

enum UploadEventResult {
  CREATED
  EXACT_DUPLICATE
  FAILED
}

enum AssetReviewAction {
  APPROVE
  RETURN
  INTERNAL_ONLY
  REJECT
}

model Integration {
  id               String           @id @default(cuid())
  kind             IntegrationKind  @unique
  displayName      String
  state            IntegrationState @default(UNCONFIGURED)
  capabilities     String[]
  capabilityStatus Json             @default("{}")
  region           String           @default("CN")
  publicConfig     Json             @default("{}")
  secretRef        String?
  lastCheckedAt    DateTime?
  lastSuccessAt    DateTime?
  message          String           @default("未配置")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  publishJobs       PublishJob[]
  metrics           MetricSnapshot[]
  comments          CommentRecord[]
  liveRooms         LiveSession[]
  shopItems         ShopWorkItem[]
  accounts          PlatformAccount[]
  importBatches     ImportBatch[]
  businessSnapshots BusinessSnapshot[]
  healthHistory     DataSourceHealth[]
  attributions      AttributionTouch[]
}

model Department {
  id        String   @id @default(cuid())
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees Employee[]
}

model Employee {
  id           String   @id @default(cuid())
  employeeNo   String?  @unique
  name         String
  departmentId String?
  role         String   @default("运营")
  wecomUserId  String?  @unique
  mobileMasked String?
  status       String   @default("ACTIVE")
  isSuperAdmin Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department      Department?           @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  ownedAccounts   PlatformAccount[]
  ownedStores     Store[]
  assignedContent ContentPlan[]
  publishJobs     PublishJob[]
  assetVersions   AssetVersion[]
  importBatches   ImportBatch[]
  businessItems   BusinessSnapshot[]
  attributions    AttributionTouch[]
  uploadBatches   UploadBatch[]
  uploadEvents    UploadEvent[]
  assetReviews    AssetReviewDecision[]
  assetUsages     AssetUsage[]
  assets          Asset[]
  remakeTasks     RemakeTask[]

  @@index([departmentId, status])
  @@index([name])
}

model Product {
  id          String       @id @default(cuid())
  name        String
  modelCode   String       @unique
  category    String
  evidenceIds String[]     @default([])
  status      RecordStatus @default(PENDING)
  metadata    Json         @default("{}")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  skus        ProductSku[]
  assets      AssetProduct[]
  faqEntries  FaqEntry[]
  remakeTasks RemakeTask[]

  @@index([category, status])
}

model ProductSku {
  id               String   @id @default(cuid())
  productId        String
  skuCode          String   @unique
  name             String
  attributes       Json     @default("{}")
  externalMappings Json     @default("{}")
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, active])
}

model PlatformAccount {
  id                String           @id @default(cuid())
  integrationId     String
  accountName       String
  externalAccountId String
  region            String           @default("CN")
  state             IntegrationState @default(UNCONFIGURED)
  capabilityStatus  Json             @default("{}")
  ownerEmployeeId   String?
  message           String           @default("未配置")
  lastCheckedAt     DateTime?
  lastSuccessAt     DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  integration       Integration        @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  ownerEmployee     Employee?          @relation(fields: [ownerEmployeeId], references: [id], onDelete: SetNull)
  stores            Store[]
  publishJobs       PublishJob[]
  importBatches     ImportBatch[]
  businessSnapshots BusinessSnapshot[]
  healthHistory     DataSourceHealth[]
  attributions      AttributionTouch[]
  contentVariants   ContentVariant[]

  @@unique([integrationId, externalAccountId])
  @@index([region, state])
}

model Store {
  id                String           @id @default(cuid())
  platformAccountId String
  name              String
  externalStoreId   String
  region            String           @default("CN")
  state             IntegrationState @default(UNCONFIGURED)
  ownerEmployeeId   String?
  metadata          Json             @default("{}")
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  platformAccount   PlatformAccount    @relation(fields: [platformAccountId], references: [id], onDelete: Cascade)
  ownerEmployee     Employee?          @relation(fields: [ownerEmployeeId], references: [id], onDelete: SetNull)
  businessSnapshots BusinessSnapshot[]

  @@unique([platformAccountId, externalStoreId])
  @@index([region, state])
}

model Asset {
  id              String       @id @default(cuid())
  sourceKey       String       @unique
  sourceType      String
  sourcePath      String
  fileName        String
  extension       String
  mediaType       String
  sha256          String
  sizeBytes       BigInt
  modifiedAt      DateTime
  width           Int?
  height          Int?
  durationSeconds Float?
  aspectRatio     String?
  model           String?
  scene           String?
  evidenceIds     String[]
  restriction     String?
  status          RecordStatus @default(PENDING)
  qualityScore    Int          @default(0)
  useCount        Int          @default(0)
  lastUsedAt      DateTime?
  performance     Json         @default("{}")
  sourceSnapshot  Json         @default("{}")
  storageProvider String       @default("LOCAL_SOURCE")
  objectKey       String?
  objectVersionId String?
  etag            String?
  storageUrl      String?
  storageSyncedAt DateTime?
  storageError    String?
  discoveredBy    String       @default("系统素材扫描")
  reviewedBy      String?
  reviewedAt      DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  assetNo             String?                 @unique
  displayName         String?
  kind                AssetKind?
  level               AssetLevel              @default(ORIGINAL)
  productScope        ProductScope            @default(UNKNOWN)
  processingStatus    AssetProcessingStatus   @default(RECEIVED)
  reviewStatus        AssetReviewStatus       @default(PENDING)
  availabilityStatus  AssetAvailabilityStatus @default(INACTIVE)
  rightsStatus        AssetRightsStatus       @default(AUTH_REQUIRED)
  originalFileName    String?
  contentDescription  String?
  acquiredAt          DateTime?
  isOriginal          Boolean                 @default(false)
  perceptualHash      String?
  analysisVersion     Int                     @default(0)
  lastAnalysisAt      DateTime?
  createdByEmployeeId String?

  contentAssets     ContentAsset[]
  versions          AssetVersion[]
  createdByEmployee Employee?             @relation(fields: [createdByEmployeeId], references: [id], onDelete: SetNull)
  products          AssetProduct[]
  tags              AssetTag[]
  parentRelations   AssetRelation[]       @relation("AssetRelationParent")
  childRelations    AssetRelation[]       @relation("AssetRelationChild")
  uploadEvents      UploadEvent[]
  analysisJobs      AssetAnalysisJob[]
  reviewDecisions   AssetReviewDecision[]
  usages            AssetUsage[]
  metricSnapshots   AssetMetricSnapshot[]
  segments          AssetSegment[]
  cloudMediaJobs    CloudMediaJob[]
  scoreSnapshots    AssetScoreSnapshot[]

  @@index([sha256])
  @@index([model, status])
  @@index([storageProvider, storageSyncedAt])
  @@index([kind, level, processingStatus])
  @@index([reviewStatus, availabilityStatus, rightsStatus])
  @@index([createdByEmployeeId, createdAt])
  @@index([perceptualHash])
}

model AssetVersion {
  id                  String   @id @default(cuid())
  assetId             String
  version             Int
  sha256              String
  sourcePath          String
  objectKey           String?
  objectVersionId     String?
  etag                String?
  storageUrl          String?
  createdByEmployeeId String?
  createdBy           String
  createdAt           DateTime @default(now())
  originalFileName    String?
  mimeType            String?
  extension           String?
  sizeBytes           BigInt?
  width               Int?
  height              Int?
  durationSeconds     Float?
  codec               String?
  previewObjectKey    String?
  previewUrl          String?
  technicalMetadata   Json     @default("{}")

  asset             Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  createdByEmployee Employee? @relation(fields: [createdByEmployeeId], references: [id], onDelete: SetNull)

  @@unique([assetId, version])
  @@index([sha256])
}

model BrandProfileVersion {
  id             String       @id @default(cuid())
  version        Int          @unique
  title          String
  positioning    String?
  story          String?
  tone           Json         @default("{}")
  visual         Json         @default("{}")
  marketVersions Json         @default("{}")
  source         String
  status         RecordStatus @default(PENDING)
  approvedBy     String?
  approvedAt     DateTime?
  effectiveAt    DateTime?
  createdBy      String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model FaqEntry {
  id               String       @id @default(cuid())
  faqNo            String       @unique
  standardQuestion String
  shortAnswer      String
  detailedAnswer   String?
  category         String
  intent           String
  language         String       @default("zh-CN")
  market           String       @default("CN")
  frequency        Int          @default(0)
  priority         String       @default("NORMAL")
  source           String
  sourceLevel      String       @default("B")
  productId        String?
  status           RecordStatus @default(PENDING)
  externallyUsable Boolean      @default(false)
  validUntil       DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  product  Product?     @relation(fields: [productId], references: [id], onDelete: SetNull)
  variants FaqVariant[]

  @@index([category, status, frequency])
  @@index([productId, market, language])
}

model FaqVariant {
  id        String   @id @default(cuid())
  faqId     String
  question  String
  source    String
  frequency Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  faq FaqEntry @relation(fields: [faqId], references: [id], onDelete: Cascade)

  @@unique([faqId, question])
}

model AssetProduct {
  assetId    String
  productId  String
  scope      ProductScope @default(MODEL)
  confidence Float?
  confirmed  Boolean      @default(false)
  createdAt  DateTime     @default(now())

  asset   Asset   @relation(fields: [assetId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([assetId, productId])
  @@index([productId, confirmed])
}

model TagDefinition {
  id          String   @id @default(cuid())
  namespace   String
  code        String
  label       String
  description String?
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assets AssetTag[]

  @@unique([namespace, code])
  @@index([namespace, active, sortOrder])
}

model AssetTag {
  assetId      String
  tagId        String
  source       AssetTagSource
  confidence   Float?
  confirmed    Boolean        @default(false)
  locked       Boolean        @default(false)
  modelVersion String?
  createdBy    String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  asset Asset         @relation(fields: [assetId], references: [id], onDelete: Cascade)
  tag   TagDefinition @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([assetId, tagId])
  @@index([tagId, confirmed])
}

model AssetRelation {
  id            String            @id @default(cuid())
  parentAssetId String
  childAssetId  String
  type          AssetRelationType
  score         Float?
  metadata      Json              @default("{}")
  createdBy     String
  createdAt     DateTime          @default(now())

  parentAsset Asset @relation("AssetRelationParent", fields: [parentAssetId], references: [id], onDelete: Cascade)
  childAsset  Asset @relation("AssetRelationChild", fields: [childAssetId], references: [id], onDelete: Cascade)

  @@unique([parentAssetId, childAssetId, type])
  @@index([childAssetId, type])
}

model UploadBatch {
  id                   String            @id @default(cuid())
  batchNo              String            @unique
  status               UploadBatchStatus @default(DRAFT)
  sourceType           String
  productScope         ProductScope      @default(UNKNOWN)
  productIds           String[]          @default([])
  assetKind            AssetKind?
  contentDescription   String?
  originalStatus       Boolean           @default(false)
  rightsStatus         AssetRightsStatus @default(AUTH_REQUIRED)
  acquiredAt           DateTime?
  uploadedByEmployeeId String?
  uploadedBy           String
  receivedCount        Int               @default(0)
  createdCount         Int               @default(0)
  duplicateCount       Int               @default(0)
  failedCount          Int               @default(0)
  completedAt          DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  uploadedByEmployee Employee?     @relation(fields: [uploadedByEmployeeId], references: [id], onDelete: SetNull)
  events             UploadEvent[]

  @@index([status, createdAt])
  @@index([uploadedByEmployeeId, createdAt])
}

model UploadEvent {
  id                   String            @id @default(cuid())
  uploadBatchId        String
  assetId              String?
  uploadedByEmployeeId String?
  originalFileName     String
  sha256               String?
  sizeBytes            BigInt
  result               UploadEventResult
  failureReason        String?
  occurredAt           DateTime          @default(now())

  batch    UploadBatch @relation(fields: [uploadBatchId], references: [id], onDelete: Cascade)
  asset    Asset?      @relation(fields: [assetId], references: [id], onDelete: SetNull)
  employee Employee?   @relation(fields: [uploadedByEmployeeId], references: [id], onDelete: SetNull)

  @@index([uploadBatchId, result])
  @@index([assetId, occurredAt])
}

model AssetAnalysisJob {
  id            String         @id @default(cuid())
  assetId       String
  type          AssetJobType
  status        AssetJobStatus @default(PENDING)
  provider      String
  model         String?
  modelVersion  String?
  attempts      Int            @default(0)
  maxAttempts   Int            @default(4)
  nextAttemptAt DateTime?
  startedAt     DateTime?
  finishedAt    DateTime?
  failureReason String?
  input         Json           @default("{}")
  result        Json           @default("{}")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, type, modelVersion])
  @@index([status, nextAttemptAt, createdAt])
}

model AssetReviewDecision {
  id                 String            @id @default(cuid())
  assetId            String
  action             AssetReviewAction
  note               String?
  reviewerEmployeeId String?
  reviewer           String
  before             Json              @default("{}")
  after              Json              @default("{}")
  createdAt          DateTime          @default(now())

  asset    Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  employee Employee? @relation(fields: [reviewerEmployeeId], references: [id], onDelete: SetNull)

  @@index([assetId, createdAt])
}

model AssetUsage {
  id                 String           @id @default(cuid())
  assetId            String
  usageType          String
  businessObjectType String
  businessObjectId   String
  usedByEmployeeId   String?
  usedBy             String
  actorType          ActorType        @default(HUMAN)
  purpose            String?
  platform           IntegrationKind?
  accountId          String?
  createdAt          DateTime         @default(now())

  asset    Asset                 @relation(fields: [assetId], references: [id], onDelete: Cascade)
  employee Employee?             @relation(fields: [usedByEmployeeId], references: [id], onDelete: SetNull)
  metrics  AssetMetricSnapshot[]

  @@index([assetId, createdAt])
  @@index([businessObjectType, businessObjectId])
}

model AssetMetricSnapshot {
  id                String           @id @default(cuid())
  assetId           String
  usageId           String?
  platform          IntegrationKind?
  accountId         String?
  externalId        String?
  capturedAt        DateTime
  views             Int?
  likes             Int?
  comments          Int?
  shares            Int?
  saves             Int?
  consultations     Int?
  orders            Int?
  revenue           Decimal?         @db.Decimal(18, 2)
  unavailableFields String[]         @default([])
  raw               Json             @default("{}")

  asset Asset       @relation(fields: [assetId], references: [id], onDelete: Cascade)
  usage AssetUsage? @relation(fields: [usageId], references: [id], onDelete: SetNull)

  @@index([assetId, capturedAt])
  @@index([externalId, capturedAt])
}

model AssetSegment {
  id                  String           @id @default(cuid())
  assetId             String
  startSeconds        Float
  endSeconds          Float
  transcript          String?
  moduleType          VideoModuleType?
  confidence          Float?
  status              String           @default("SUGGESTED")
  analysisVersion     Int
  previewObjectKey    String?
  materializedAssetId String?
  createdBy           String
  locked              Boolean          @default(false)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId, startSeconds])
  @@index([moduleType, status])
}

model AssetGapSnapshot {
  id             String    @id @default(cuid())
  snapshotDate   DateTime
  productId      String?
  productModel   String?
  assetKind      AssetKind
  category       String
  requiredCount  Int
  activeCount    Int
  gapCount       Int
  severity       String
  recommendation String
  generatedBy    String    @default("系统缺口分析")
  createdAt      DateTime  @default(now())

  @@unique([snapshotDate, productModel, assetKind, category])
  @@index([snapshotDate, severity])
}

model CloudMediaJob {
  id              String              @id @default(cuid())
  assetId         String?
  externalVideoId String?
  provider        CloudMediaProvider
  type            CloudMediaJobType
  status          CloudMediaJobStatus @default(PENDING)
  idempotencyKey  String              @unique
  externalJobId   String?
  model           String?
  modelVersion    String?
  inputObjectKey  String?
  requestPayload  Json                @default("{}")
  resultPayload   Json                @default("{}")
  usage           Json                @default("{}")
  attempts        Int                 @default(0)
  maxAttempts     Int                 @default(4)
  nextAttemptAt   DateTime?
  submittedAt     DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  failureReason   String?
  callbackToken   String              @unique
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  asset         Asset?             @relation(fields: [assetId], references: [id], onDelete: Cascade)
  externalVideo ExternalVideo?     @relation(fields: [externalVideoId], references: [id], onDelete: Cascade)
  outputs       CloudMediaOutput[]

  @@index([status, nextAttemptAt, createdAt])
  @@index([assetId, type])
  @@index([externalVideoId, type])
  @@index([provider, externalJobId])
}

model CloudMediaOutput {
  id          String   @id @default(cuid())
  jobId       String
  outputType  String
  objectKey   String?
  url         String?
  startSecond Float?
  endSecond   Float?
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())

  job CloudMediaJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, outputType])
  @@index([objectKey])
}

model AssetScoreSnapshot {
  id              String         @id @default(cuid())
  assetId         String?
  externalVideoId String?
  kind            AssetScoreKind
  score           Int
  grade           String
  confidence      Float?
  dimensions      Json           @default("{}")
  explanation     String?
  scoringVersion  String
  model           String?
  createdAt       DateTime       @default(now())

  asset         Asset?         @relation(fields: [assetId], references: [id], onDelete: Cascade)
  externalVideo ExternalVideo? @relation(fields: [externalVideoId], references: [id], onDelete: Cascade)

  @@index([assetId, createdAt])
  @@index([externalVideoId, createdAt])
  @@index([kind, score, createdAt])
}

model ExternalVideo {
  id                 String                  @id @default(cuid())
  platform           IntegrationKind
  externalContentId  String
  sourceUrl          String
  accountName        String?
  title              String?
  description        String?
  publishedAt        DateTime?
  discoveredAt       DateTime                @default(now())
  status             ExternalVideoStatus     @default(DISCOVERED)
  rightsStatus       AssetRightsStatus       @default(INTERNAL)
  level              AssetLevel              @default(REFERENCE)
  availabilityStatus AssetAvailabilityStatus @default(INACTIVE)
  sourceObjectKey    String?
  previewObjectKey   String?
  transcript         String?
  moduleSummary      Json                    @default("[]")
  analysis           Json                    @default("{}")
  failureReason      String?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  metrics        ExternalMetricSnapshot[]
  cloudMediaJobs CloudMediaJob[]
  scoreSnapshots AssetScoreSnapshot[]
  remakeTasks    RemakeTask[]

  @@unique([platform, externalContentId])
  @@index([platform, status, discoveredAt])
  @@index([publishedAt])
}

model ExternalMetricSnapshot {
  id                String   @id @default(cuid())
  externalVideoId   String
  capturedAt        DateTime
  views             Int?
  likes             Int?
  comments          Int?
  shares            Int?
  saves             Int?
  followers         Int?
  unavailableFields String[] @default([])
  raw               Json     @default("{}")

  externalVideo ExternalVideo @relation(fields: [externalVideoId], references: [id], onDelete: Cascade)

  @@unique([externalVideoId, capturedAt])
  @@index([capturedAt])
}

model RemakeTask {
  id                String           @id @default(cuid())
  taskNo            String           @unique
  externalVideoId   String
  sourceStartSecond Float?
  sourceEndSecond   Float?
  productId         String?
  ownerEmployeeId   String?
  status            RemakeTaskStatus @default(PENDING_CONFIRMATION)
  title             String
  reason            String
  brief             Json             @default("{}")
  score             Int
  dueAt             DateTime?
  confirmedAt       DateTime?
  completedAt       DateTime?
  createdBy         String           @default("AI爆款分析")
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  externalVideo ExternalVideo @relation(fields: [externalVideoId], references: [id], onDelete: Cascade)
  product       Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)
  ownerEmployee Employee?     @relation(fields: [ownerEmployeeId], references: [id], onDelete: SetNull)

  @@index([status, score, createdAt])
  @@index([ownerEmployeeId, status])
}

model EvidenceClaim {
  id                  String       @id
  name                String
  evidenceType        String
  source              String
  entityIdentifier    String?
  coveredObject       String?
  validFrom           DateTime?
  validUntil          DateTime?
  confirmedFact       String?
  publicWording       String?
  internalRestriction String?
  status              RecordStatus @default(PENDING)
  raw                 Json         @default("{}")
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
}

model ProductMapping {
  id                 String       @id @default(cuid())
  commercialName     String       @unique
  pageFacts          String?
  nameplateModel     String?
  registeredModel    String?
  registrationNumber String?
  productionRelation String?
  status             RecordStatus @default(PENDING)
  requiredAction     String?
  raw                Json         @default("{}")
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

model PhraseRule {
  id          String   @id @default(cuid())
  category    String
  blockedText String
  replacement String?
  condition   String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([category, blockedText])
}

model KnowledgeEntry {
  id               String       @id
  type             String
  title            String
  category         String?
  model            String?
  summary          String?
  reply            String?
  body             String?
  source           String
  sourceRefs       String?
  status           RecordStatus @default(PENDING)
  audience         String       @default("customer")
  sourceLevel      String       @default("B")
  validUntil       DateTime?
  externallyUsable Boolean      @default(false)
  evidenceIds      String[]     @default([])
  reviewedBy       String?
  reviewedAt       DateTime?
  updatedAtSource  DateTime?
  raw              Json         @default("{}")
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([type, status, audience])
}

model ContentPlan {
  id                 String        @id @default(cuid())
  planDate           DateTime
  kind               ContentKind
  topic              String
  productModel       String?
  audience           String
  objective          String
  score              Int           @default(0)
  scoreBreakdown     Json          @default("{}")
  hook               String
  outline            Json          @default("[]")
  sourceSignals      Json          @default("[]")
  evidenceIds        String[]
  status             ContentStatus @default(DRAFT)
  riskReasons        String[]
  approvedBy         String?
  approvedAt         DateTime?
  createdBy          String        @default("系统内容引擎")
  assignedTo         String?
  assignedEmployeeId String?
  actorType          ActorType     @default(AI)
  aiProvider         String?
  aiModel            String?
  promptVersion      String?
  rejectedReason     String?
  scheduledAt        DateTime?
  publishedAt        DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  variants         ContentVariant[]
  publishJobs      PublishJob[]
  approvals        Approval[]
  contentAssets    ContentAsset[]
  assignedEmployee Employee?          @relation(fields: [assignedEmployeeId], references: [id], onDelete: SetNull)
  attributions     AttributionTouch[]

  @@index([planDate, kind])
  @@index([status])
}

model ContentVariant {
  id              String          @id @default(cuid())
  contentPlanId   String
  platform        IntegrationKind
  title           String
  body            String
  mediaType       String?
  mediaPath       String?
  coverPath       String?
  targetAccountId String?
  metadata        Json            @default("{}")
  status          ContentStatus   @default(DRAFT)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  contentPlan   ContentPlan      @relation(fields: [contentPlanId], references: [id], onDelete: Cascade)
  targetAccount PlatformAccount? @relation(fields: [targetAccountId], references: [id], onDelete: SetNull)
  publishJobs   PublishJob[]

  @@unique([contentPlanId, platform])
  @@index([targetAccountId])
}

model ContentAsset {
  contentPlanId String
  assetId       String
  role          String

  contentPlan ContentPlan @relation(fields: [contentPlanId], references: [id], onDelete: Cascade)
  asset       Asset       @relation(fields: [assetId], references: [id], onDelete: Restrict)

  @@id([contentPlanId, assetId, role])
}

model Approval {
  id            String   @id @default(cuid())
  contentPlanId String
  action        String
  actor         String
  note          String?
  createdAt     DateTime @default(now())

  contentPlan ContentPlan @relation(fields: [contentPlanId], references: [id], onDelete: Cascade)
}

model PublishJob {
  id                 String    @id @default(cuid())
  idempotencyKey     String    @unique
  contentPlanId      String
  variantId          String
  integrationId      String
  status             JobStatus @default(PENDING)
  scheduledAt        DateTime
  attempts           Int       @default(0)
  nextAttemptAt      DateTime?
  remoteId           String?
  remoteUrl          String?
  receipt            Json      @default("{}")
  lastError          String?
  operator           String    @default("系统发布")
  operatorType       ActorType @default(SYSTEM)
  operatorEmployeeId String?
  platformAccountId  String?
  publishedAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  contentPlan      ContentPlan        @relation(fields: [contentPlanId], references: [id], onDelete: Cascade)
  variant          ContentVariant     @relation(fields: [variantId], references: [id], onDelete: Cascade)
  integration      Integration        @relation(fields: [integrationId], references: [id], onDelete: Restrict)
  metrics          MetricSnapshot[]
  operatorEmployee Employee?          @relation(fields: [operatorEmployeeId], references: [id], onDelete: SetNull)
  platformAccount  PlatformAccount?   @relation(fields: [platformAccountId], references: [id], onDelete: SetNull)
  attributions     AttributionTouch[]

  @@index([status, nextAttemptAt])
}

model MetricSnapshot {
  id                String   @id @default(cuid())
  integrationId     String
  publishJobId      String?
  remoteId          String
  capturedAt        DateTime
  views             Int?
  completionRate    Float?
  likes             Int?
  comments          Int?
  shares            Int?
  saves             Int?
  consultations     Int?
  orders            Int?
  unavailableFields String[]
  raw               Json     @default("{}")
  capturedBy        String   @default("系统数据巡查")

  integration Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  publishJob  PublishJob? @relation(fields: [publishJobId], references: [id], onDelete: SetNull)

  @@unique([integrationId, remoteId, capturedAt])
  @@index([remoteId, capturedAt])
}

model CommentRecord {
